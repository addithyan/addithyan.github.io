---
type SkillGroup = {
  label: string;
  items: string[];
};

const skills: SkillGroup[] = [
  { label: 'Languages', items: ['Python', 'C', 'Java', 'SQL', 'HTML/CSS'] },
  { label: 'Frameworks', items: ['React', 'Django', 'FastAPI'] },
  { label: 'Tools', items: ['Git', 'GitHub', 'Postman'] },
  { label: 'Platforms', items: ['Linux', 'VS Code'] },
];
---

<section
  id="about"
  class="py-28 px-6"
  aria-labelledby="about-heading"
>
  <div class="max-w-6xl mx-auto">
    <div class="section-reveal grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: text -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-xs text-accent-blue tracking-widest uppercase">01 / About</span>
          <span class="h-px flex-1 bg-white/5" aria-hidden="true" />
        </div>

        <h2
          id="about-heading"
          class="font-display text-4xl md:text-5xl font-bold text-text-primary mb-8 leading-tight tracking-tight"
        >
          Building with purpose,<br />
          <span class="gradient-text">learning always</span>
        </h2>

        <p class="text-text-secondary leading-relaxed text-base md:text-lg mb-6 font-light">
          I am a B.Tech Computer Science graduate currently working as a Full Stack Developer at Grey Codes. I build web applications and solve real-world problems using technology.
        </p>
        <p class="text-text-secondary leading-relaxed text-base md:text-lg mb-10 font-light">
          I have experience in both frontend and backend development and continuously improve my skills. I am a collaborative team player, eager to take on new challenges and deliver quality solutions.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4">
          {[
            { value: '8+', label: 'Months Exp.' },
            { value: '5+', label: 'Projects Built' },
            { value: '1', label: 'Company' },
          ].map((stat) => (
            <div class="p-5 rounded-xl border border-white/6 bg-surface-1/50 text-center">
              <p class="font-display text-3xl font-bold gradient-text">{stat.value}</p>
              <p class="text-xs text-text-muted mt-1 font-mono tracking-wide">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: skills + education (same height via flex) -->
      <div class="flex flex-col gap-5">
        {
          skills.map((group) => (
            <div class="p-5 rounded-xl border border-white/6 bg-surface-1/40 hover:border-white/12 transition-colors duration-300">
              <p class="text-xs font-mono text-text-muted mb-3 tracking-widest uppercase">{group.label}</p>
              <div class="flex flex-wrap gap-2">
                {group.items.map((skill) => (
                  <span class="px-3 py-1.5 rounded-lg text-sm text-text-secondary bg-white/4 border border-white/6 hover:border-accent-blue/30 hover:text-text-primary transition-all duration-200">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))
        }

        <!-- Education -->
        <div class="flex-1 p-5 rounded-xl border border-white/6 bg-surface-1/40 hover:border-white/12 transition-colors duration-300">
          <p class="text-xs font-mono text-text-muted mb-4 tracking-widest uppercase">Education</p>
          <div class="space-y-4">
            <div>
              <p class="text-sm font-semibold text-text-primary">B.Tech Computer Science Engineering</p>
              <p class="text-xs text-text-muted mt-1">St. Joseph's College of Engineering and Technology · 2021–2025</p>
            </div>
            <div class="h-px bg-white/5" aria-hidden="true" />
            <div>
              <p class="text-sm font-semibold text-text-primary">Higher Secondary Education</p>
              <p class="text-xs text-text-muted mt-1">S N D P H S S Udayamperoor · 2019–2021</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>