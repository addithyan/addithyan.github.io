---
const year = new Date().getFullYear();
---

<footer class="py-10 px-6 border-t border-white/5" aria-label="Site footer">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <span class="font-display font-bold gradient-text text-lg">AB</span>
      <span class="text-text-muted text-xs font-mono">Adithyan B · Full Stack Developer</span>
    </div>

    <p class="text-text-muted text-xs font-mono text-center">
      © {year} · Built with Astro & Tailwind CSS
    </p>

    <nav class="flex items-center gap-5" aria-label="Footer navigation">
      <a href="#about" class="text-xs text-text-muted hover:text-text-secondary transition-colors">About</a>
      <a href="#projects" class="text-xs text-text-muted hover:text-text-secondary transition-colors">Projects</a>
      <a href="#contact" class="text-xs text-text-muted hover:text-text-secondary transition-colors">Contact</a>
    </nav>
  </div>
</footer>